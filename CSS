/* Resetando margens e preenchimentos */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html, body {
    height: 100%; /* Garantir que o body ocupe toda a altura da tela */
}

body {
    display: flex;
    flex-direction: column; /* Organiza os elementos do body em coluna */
}

.content {
    flex: 1; /* Faz o conteúdo ocupar o máximo de espaço disponível */
    padding: 20px;
}

.footer {
    background-color: #333;
    color: white;
    text-align: center;
    padding: 10px;
    position: relative;
    bottom: 0;
