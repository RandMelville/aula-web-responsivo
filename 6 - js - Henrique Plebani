// Obtém o formulário com o id "form-contato"
const form = document.getElementById("form-contato");

// Adiciona um evento de "submit" (envio) no formulário
form.addEventListener("submit", function (event) {
    // Obtém os valores dos campos do formulário: nome, email e mensagem
    const nome = document.getElementById("nome").value;
    const email = document.getElementById("email").value;
    const mensagem = document.getElementById("mensagem").value;

    // Verifica se algum campo está vazio (usando trim() para remover espaços extras)
    if (nome.trim() === "" || email.trim() === "" || mensagem.trim() === "") {
        // Se algum campo estiver vazio, exibe uma mensagem de alerta
        alert("Por favor, preencha todos os campos.");
        
        // Impede o envio do formulário
        event.preventDefault();
    } else {
        // Se todos os campos estiverem preenchidos, exibe uma mensagem de sucesso
        alert("Formulário enviado com sucesso!");
    }
});
